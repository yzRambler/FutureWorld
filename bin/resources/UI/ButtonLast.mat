{
    "Material": {
        "Name": "BtnLastMatl",
        "NameFile": "./resources/UI/ButtonLast.mat",
        "Order": 500,
        "RenderType": "Transparent",
        "TextureUnits": [
            {  "NameSampler": "u_Sampler",
               "Texture": {
                   "Name": "NormalTexture",
                   "NameFile": "./resources/UI/ButtonLast_normal.png"
                }
             },
             {
                "NameSampler": "u_Sampler",
                "Texture": {
                    "Name": "HoverTexture",
                    "NameFile": "./resources/UI/ButtonLast_hover.png"
                }
             },
             {
                "NameSampler": "u_Sampler",
                "Texture": {
                    "Name": "PressTexture",
                    "NameFile": "./resources/UI/ButtonLast_press.png"
                }
             }
        ],
        "Passes": [
        		{
        				
        				"Program": {
        				    "VertexAttribute": [
        				        {"DataType": "vec3", "VarName": "aPosition", "AttrType": "VertexPos"},
                        {"DataType": "vec2", "VarName": "aTexCoord", "AttrType": "VertexUV"}
        				    ],
        				    "ParameterUniform":[
        				        {"DataType": "mat4", "VarName": "uMatMVP", "Class": "Camera", "Value": "ModelViewProjection"},
        				        {"DataType": "samp2", "VarName": "uSampler", "Class": "Texture", "Ind": 0},
        				        {"DataType": "samp2", "VarName": "uSampler", "Class": "Texture", "Ind": 1},
        				        {"DataType": "samp2", "VarName": "uSampler", "Class": "Texture", "Ind": 2}
        				    ],
                		"VertexShader": {
                    		"Name": "VertexShader",
                    		"NameFile": "./resources/VSSingleTexture.txt"
                		},
                		"FragmentShader": {
                    		"Name": "FragmentShader",
                    		"NameFile": "./resources/FSSingleTexture.txt"
                		}
            		},
            		"Command": [
            				{"Name": "Enable", "Value": "Blend"},
            				{"Name": "Disable", "Value": "Depth"},
            				{"Name": "BlendFunc", "Value": { "Src":"SA", "Tag":"1-SA" }}
            		]
        		}
        ]
    }
}